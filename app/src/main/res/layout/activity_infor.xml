<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:background="@color/white"
    tools:context=".Activity.InforActivity" >

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="281dp">

        <ImageView
            android:id="@+id/backBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:elevation="8dp"
            android:padding="8dp"
            android:src="@drawable/arrow"
            android:visibility="visible" />

        <TextView
            android:id="@+id/tVProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="23dp"
            android:fontFamily="@font/inter_extrabold"
            android:text="Profile"
            android:textSize="20dp" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cVAvt"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_below="@id/tVProfile"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="30dp"
            app:cardCornerRadius="75dp">

            <ImageView
                android:id="@+id/imgAvt"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/img_ngoisao" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cVEdit"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignEnd="@id/cVAvt"
            android:layout_alignBottom="@id/cVAvt"
            android:layout_marginEnd="-15dp"
            android:layout_marginBottom="-15dp"
            app:cardCornerRadius="24dp">

            <ImageView
                android:id="@+id/imgPenCard"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ta_colormauhong" />

            <ImageView
                android:id="@+id/imgPen"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:layout_gravity="center"
                android:src="@drawable/ta_peniconwhite" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tVTen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/cVAvt"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/inter_extrabold"
            android:text="httanhhh"
            android:textSize="16dp" />

    </RelativeLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="-10dp"
            android:padding="10dp">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ta_personicon" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:fontFamily="@font/inter_medium"
                android:text="Your profile"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/bntNextProfile"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginEnd="-40dp"
                android:src="@drawable/ta_nexticon2" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#BFBABA" />

    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="-10dp"
            android:padding="10dp">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ta_cardicon" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:fontFamily="@font/inter_medium"
                android:text="Payment Methods"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/bntNextPayment"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginEnd="-40dp"
                android:src="@drawable/ta_nexticon2" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#BFBABA" />

    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="-10dp"
            android:padding="10dp">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ta_ordericon" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:fontFamily="@font/inter_medium"
                android:text="My Orders"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/bntNextMyOrders"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginEnd="-40dp"
                android:src="@drawable/ta_nexticon2" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#BFBABA" />

    </LinearLayout>
</LinearLayout>
