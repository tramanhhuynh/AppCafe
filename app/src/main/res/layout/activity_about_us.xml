<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8D5E1"
    android:fillViewport="true"
    tools:context=".Activity.AboutUs">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/BntBackAboutUs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:elevation="8dp"
            android:padding="8dp"
            android:src="@drawable/arrow"
            android:visibility="visible" />

        <TextView
            android:id="@+id/tVLogoAboutUs"
            android:layout_width="271dp"
            android:layout_height="125dp"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/inter_extrabold"
            android:text="GócCàPhê Coffee"
            android:textSize="40dp" />

        <com.makeramen.roundedimageview.RoundedImageView
            android:layout_width="wrap_content"
            android:layout_height="425dp"
            android:layout_marginLeft="30dp"
            android:layout_marginTop="20dp"
            android:src="@drawable/ta_aboutus"
            app:riv_corner_radius_bottom_left="20dp"
            app:riv_corner_radius_bottom_right="20dp"
            app:riv_corner_radius_top_left="20dp"
            app:riv_corner_radius_top_right="20dp" />

        <TextView
            android:id="@+id/tVAboutUs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginRight="20dp"
            android:fontFamily="@font/inter_medium"
            android:text="GócCàPhê is a notable café with a cozy and friendly atmosphere, perfect for meeting friends, working, or relaxing after stressful study and work hours. The café is often decorated with familiar details, creating a comfortable feeling for customers.
The menu at Góc Cà Phê is very diverse, featuring traditional coffee options like iced milk coffee and cappuccino, as well as various teas and creative beverages. Additionally, the café offers light snacks such as pastries and sandwiches, allowing customers to enjoy something while working or chatting." />

    </LinearLayout>
</ScrollView>