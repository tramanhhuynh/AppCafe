<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    tools:context=".Activity.InforEditActivity">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="239dp">

        <ImageView
            android:id="@+id/backBtn2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:elevation="8dp"
            android:padding="8dp"
            android:src="@drawable/arrow"
            android:visibility="visible" />

        <TextView
            android:id="@+id/tVProfile2"
            android:layout_width="100dp"
            android:layout_height="30dp"
            android:layout_marginLeft="180dp"
            android:layout_marginTop="23dp"
            android:fontFamily="@font/inter_extrabold"
            android:text="Profile"
            android:textSize="20dp" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cVAvt2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="145dp"
            android:layout_marginTop="90dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="100dp"
            app:layout_constraintBottom_toTopOf="@+id/button"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/imgAvt2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scaleType="centerCrop"
                android:src="@drawable/img_ngoisao" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cVEdit2"
            android:layout_width="48dp"
            android:layout_height="43dp"
            android:layout_marginStart="250dp"
            android:layout_marginTop="175dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="100dp"
            app:layout_constraintBottom_toTopOf="@+id/button"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/imgPenCard2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scaleType="centerCrop"
                android:src="@drawable/ta_colormauhong" />

            <ImageView
                android:id="@+id/imgPen2"
                android:layout_width="34dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ta_peniconwhite" />
        </androidx.cardview.widget.CardView>

    </FrameLayout>

    <TextView
        android:id="@+id/tVTenEdit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:text="Name"
        android:fontFamily="@font/inter_medium"/>

    <EditText
        android:id="@+id/edtTen"
        android:layout_width="374dp"
        android:layout_height="55dp"
        android:layout_gravity="center"
        android:layout_marginTop="5dp"
        android:background="@drawable/edittext_background2"
        android:ems="10"
        android:inputType="text" />

    <TextView
        android:id="@+id/tVSdt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:text="Phone"
        android:fontFamily="@font/inter_medium"/>

    <EditText
        android:id="@+id/edtSdt"
        android:layout_width="374dp"
        android:layout_height="55dp"
        android:layout_gravity="center"
        android:layout_marginTop="5dp"
        android:background="@drawable/edittext_background2"
        android:ems="10"
        android:inputType="phone" />

    <TextView
        android:id="@+id/tVEmai"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:text="Email"
        android:fontFamily="@font/inter_medium"/>

    <EditText
        android:id="@+id/edtEmail"
        android:layout_width="374dp"
        android:layout_height="55dp"
        android:layout_gravity="center"
        android:layout_marginTop="5dp"
        android:background="@drawable/edittext_background2"
        android:ems="10"
        android:inputType="textEmailAddress" />

    <TextView
        android:id="@+id/tVGioitinh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:text="Gender"
        android:fontFamily="@font/inter_medium"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="71dp">
        <Spinner
            android:id="@+id/spinner_Select"
            android:layout_width="374dp"
            android:layout_height="55dp"
            android:layout_gravity="center"
            android:layout_marginTop="5dp"
            android:background="@drawable/edittext_background2"
            android:spinnerMode="dropdown" />

        <ImageView
            android:id="@+id/imgSelect"
            android:layout_width="39dp"
            android:layout_height="33dp"
            android:layout_marginTop="25dp"
            android:layout_marginLeft="340dp"
            android:background="@drawable/ta_dropdownicon" />
    </FrameLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="257dp"
        android:layout_marginTop="170dp"
        android:background="@drawable/backroundedit">

        <Button
            android:id="@+id/btnEditProfile"
            android:layout_width="230dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="90dp"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/inter_extrabold"
            android:text="Update"
            android:backgroundTint="#F3ED82A6"/>
    </FrameLayout>


</LinearLayout>