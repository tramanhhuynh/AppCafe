<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    tools:context=".Activity.PaymentmethodsActivity">

    <ImageView
        android:id="@+id/backBtn4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:elevation="8dp"
        android:padding="8dp"
        android:src="@drawable/arrow"
        android:visibility="visible" />

    <TextView
        android:id="@+id/tVPayment"
        android:layout_width="wrap_content"
        android:layout_height="30dp"
        android:layout_marginLeft="100dp"
        android:fontFamily="@font/inter_extrabold"
        android:text="Payment Menthods"
        android:textSize="20dp" />

    <TextView
        android:id="@+id/tVCash"
        android:layout_width="207dp"
        android:layout_height="30dp"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="30dp"
        android:fontFamily="@font/inter_tight_semibold"
        android:text="Cash"
        android:textSize="18dp" />

    <FrameLayout
        android:layout_width="371dp"
        android:layout_height="50dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/backround_item_coupon"
        android:layout_marginLeft="20dp">


        <ImageView
            android:id="@+id/imgCash"
            android:layout_width="38dp"
            android:layout_height="28dp"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/ta_cashicon" />

        <TextView
            android:id="@+id/tVCashHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cash"
            android:textSize="16dp"
            android:fontFamily="@font/inter_tight_semibold"
            android:layout_marginTop="15dp"
            android:layout_marginLeft="60dp"
            android:textColor="#9F9C9C"/>

        <RadioButton
            android:id="@+id/rdBCash"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="#DD7498"
            android:layout_gravity="right"/>
    </FrameLayout>

    <TextView
        android:id="@+id/tVWallet"
        android:layout_width="207dp"
        android:layout_height="30dp"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/inter_tight_semibold"
        android:text="Wallet"
        android:textSize="18dp" />
    <FrameLayout
        android:layout_width="371dp"
        android:layout_height="50dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/backround_item_coupon"
        android:layout_marginLeft="20dp">


        <ImageView
            android:id="@+id/imgWallet"
            android:layout_width="38dp"
            android:layout_height="28dp"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/ta_walleticon" />

        <TextView
            android:id="@+id/tVWalletHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wallet"
            android:textSize="16dp"
            android:fontFamily="@font/inter_tight_semibold"
            android:layout_marginTop="15dp"
            android:layout_marginLeft="60dp"
            android:textColor="#9F9C9C"/>

        <RadioButton
            android:id="@+id/rdBWallet"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="#DD7498"
            android:layout_gravity="right"/>
    </FrameLayout>

    <TextView
        android:id="@+id/tVCard"
        android:layout_width="207dp"
        android:layout_height="30dp"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/inter_tight_semibold"
        android:text="Credit and Debit Card"
        android:textSize="18dp" />
    <FrameLayout
        android:layout_width="371dp"
        android:layout_height="50dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/backround_item_coupon"
        android:layout_marginLeft="20dp">


        <ImageView
            android:id="@+id/imgCard"
            android:layout_width="38dp"
            android:layout_height="28dp"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/ta_walleticon" />

        <TextView
            android:id="@+id/tVCardHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Card"
            android:fontFamily="@font/inter_tight_semibold"
            android:textSize="16dp"
            android:layout_marginTop="15dp"
            android:layout_marginLeft="60dp"
            android:textColor="#9F9C9C"/>

        <ImageButton
            android:id="@+id/imgBtnCard"
            android:layout_width="29dp"
            android:layout_marginTop="10dp"
            android:layout_gravity="right"
            android:layout_marginRight="15dp"
            android:layout_height="29dp"
            android:background="@drawable/ta_nexticon" />


    </FrameLayout>
    <TextView
        android:id="@+id/tVMorePay"
        android:layout_width="207dp"
        android:layout_height="30dp"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="30dp"
        android:fontFamily="@font/inter_tight_semibold"
        android:text="More Payment Options"
        android:textSize="18dp" />
    <FrameLayout
        android:layout_width="371dp"
        android:layout_height="110dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/backround_item_coupon"
        android:layout_marginLeft="20dp">


        <ImageView
            android:id="@+id/imgMorePay"
            android:layout_width="38dp"
            android:layout_height="28dp"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/ta_paypalicon" />

        <TextView
            android:id="@+id/tVMorePayHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Paypal"
            android:textSize="16dp"
            android:fontFamily="@font/inter_tight_semibold"
            android:layout_marginTop="15dp"
            android:layout_marginLeft="60dp"
            android:textColor="#9F9C9C"/>

        <RadioButton
            android:id="@+id/rdBMorePay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="#DD7498"
            android:layout_gravity="right"/>
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="55dp"
            android:background="#C5C1C1"/>
        <ImageView
            android:id="@+id/imgMorePay2"
            android:layout_width="38dp"
            android:layout_height="28dp"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="70dp"
            android:background="@drawable/ta_googlepayicon" />

        <TextView
            android:id="@+id/tVMorePay2Hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Google Pay"
            android:textSize="16dp"
            android:fontFamily="@font/inter_tight_semibold"
            android:layout_marginTop="75dp"
            android:layout_marginLeft="60dp"
            android:textColor="#9F9C9C"/>

        <RadioButton
            android:id="@+id/rdBMorePay2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="#DD7498"
            android:layout_marginTop="60dp"
            android:layout_gravity="right"/>
    </FrameLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginTop="200dp"
        android:background="@drawable/backroundedit">

        <Button
            android:id="@+id/button3"
            android:layout_width="230dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="90dp"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/inter_extrabold"
            android:text="Confirm Payment"
            android:backgroundTint="#F3ED82A6"/>
    </FrameLayout>


</LinearLayout>